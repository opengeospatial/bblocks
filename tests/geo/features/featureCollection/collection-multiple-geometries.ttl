@prefix geojson: <https://purl.org/geojson/vocab#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.example.com/features/ls1> a geojson:Feature ;
    geojson:geometry [ a geojson:LineString ;
            geojson:coordinates ( ( 1.747e+02 -3.69e+01 ) ( 1.75e+02 -3.71e+01 ) ) ] .

<http://www.example.com/features/nogeom1> a geojson:Feature .

<http://www.example.com/features/pt1> a geojson:Feature ;
    geojson:geometry [ a geojson:Point ;
            geojson:coordinates ( 1.747502e+02 -3.693074e+01 ) ] .

[] a geojson:FeatureCollection ;
    geojson:features <http://www.example.com/features/ls1>,
        <http://www.example.com/features/nogeom1>,
        <http://www.example.com/features/pt1> .

